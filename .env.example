# ==========================================
# Remnawave API settings
# ==========================================
# Your panel URL (with https:// and no trailing slash).
PANEL_URL=https://panel.your-domain.com

# API token (created in the panel: Settings -> API Tokens; needs Subscription Template Read/Write)
API_TOKEN=rw_YOUR_TOKEN_HERE

# ==========================================
# Client support toggles
# ==========================================
# Happ support: updates the built-in happRouting field and any Happ-like rule. On by default.
ENABLE_HAPP=true

# INCY support: updates any Incy-like rule, or creates a default one if none exists. Off by default.
ENABLE_INCY=false

# responseType for the AUTO-CREATED INCY rule only. Existing rules keep their own type.
INCY_RESPONSE_TYPE=XRAY_BASE64

# ==========================================
# Routing generation
# ==========================================
# URL your web server serves routing.json from (required for INCY autorouting).
# MUST exactly match the public URL from the reverse proxy setup (see README).
AUTOROUTING_URL=https://sub.your-domain.com/routing.json

# Update interval in seconds. 21600 = 6 hours
UPDATE_INTERVAL_SECONDS=21600

# HTTP request timeout in seconds
REQUEST_TIMEOUT_SECONDS=30

# Retries on a network error
RETRY_ATTEMPTS=3

# ==========================================
# Geo database mirror (for regions where GitHub is blocked)
# ==========================================
# Download geoip.dat / geosite.dat to this server and serve them from your domain.
GEO_MIRROR_ENABLED=false

# Public URLs handed to clients. Point them at your reverse proxy, next to routing.json.
# Leave empty to keep the template default (GitHub) — needed only when the mirror is on.
GEOIP_URL=https://sub.your-domain.com/geoip.dat
GEOSITE_URL=https://sub.your-domain.com/geosite.dat

# Where the server pulls the databases from (default: Loyalsoldier releases on GitHub).
# Change to a mirror only if GitHub is unreachable from the server itself.
# GEOIP_SOURCE_URL=https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geoip.dat
# GEOSITE_SOURCE_URL=https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geosite.dat

# Trim the served databases to only the categories your template uses (server-side
# equivalent of the client's UseChunkFiles). Clients then download a tiny file instead
# of the full ~10-17 MB — a big win over throttled/DPI'd links. Needs GEO_MIRROR_ENABLED.
GEO_TRIM_ENABLED=false

# ==========================================
# LastUpdated stamping
# ==========================================
# interval      — bump the stamp every cycle (default, previous behaviour).
# on_geo_change — bump only when the mirrored database actually changed. Recommended
#                 together with GEO_MIRROR_ENABLED: the panel is patched only on a real
#                 update, so you can safely lower UPDATE_INTERVAL_SECONDS.
STAMP_MODE=interval
